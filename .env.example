# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# CULQI_SECRET_KEY: Required for backend charges in Culqi (starts with sk_test_ or sk_live_).
CULQI_SECRET_KEY="sk_test_..."

# VITE_CULQI_PUBLISHABLE_KEY: Required for frontend Culqi checkout (starts with pk_test_ or pk_live_).
VITE_CULQI_PUBLISHABLE_KEY="pk_test_..."

# CONFIGURACIÓN DE CORREO (Notificaciones de nuevos pedidos):
# EMAIL_USER: Cuenta de correo donde se recibirán las notificaciones (ej: gpasachet@gmail.com)
EMAIL_USER="gpasachet@gmail.com"

# EMAIL_PASS: Contraseña de aplicación de Gmail (no la contraseña normal) para permitir el envío desde el backend.
# Para generar una contraseña de aplicación, ve a tu cuenta de Google > Seguridad > Verificación en 2 pasos > Contraseñas de aplicación.
EMAIL_PASS=""

# OPCIONES ALTERNATIVAS PARA RENDER.COM (Para evitar bloqueos de puertos SMTP en Render/Cloud Run):
# Si configuras una de estas APIs, el sistema enviará los correos por HTTP (Puerto 443) el cual nunca está bloqueado.

# BREVO_API_KEY: API Key v3 de Brevo (anteriormente Sendinblue). Recomendado para envío ilimitado y fácil configuración de remitente.
BREVO_API_KEY=""

# RESEND_API_KEY: API Key de Resend (https://resend.com). Excelente alternativa gratuita (100 correos/día).
RESEND_API_KEY=""

